{
  "name": "ainder",
  "version": "0.0.0",
  "private": true,
  "description": "Template for building agentic apps on the ggui protocol \u2014 OpenAI Agents SDK variant.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:ggui": "dotenv -e .env.local -- pnpm --filter ./servers/ggui start",
    "dev:mcps": "pnpm --parallel --filter \"./servers/mcps/*\" run dev",
    "dev:ainder": "pnpm --filter ./servers/mcps/todo dev",
    "dev:agent": "dotenv -e .env.local -- pnpm --filter ./servers/agent dev",
    "dev:web": "pnpm --filter ./apps/web dev",
    "dev:stop": "node scripts/stop-dev.mjs",
    "build": "pnpm --recursive run build",
    "typecheck": "pnpm --recursive run typecheck",
    "test:security": "pnpm --filter ./servers/agent test:security",
    "test:hardening": "pnpm --filter @ainder/mcp-ainder test:hardening",
    "build:web:production": "pnpm --filter ./apps/web build",
    "bundle:check:web": "node scripts/check-web-bundle.mjs",
    "deploy:railway": "dotenv -e .env.local -- node scripts/deploy-railway.mjs",
    "env:validate": "node scripts/validate-production-env.mjs",
    "env:validate:production": "NODE_ENV=production node scripts/validate-production-env.mjs"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0"
  }
}
