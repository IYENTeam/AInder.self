# Copy to `.env.local` (git-ignored). Development may use localhost defaults;
# production deploys must provide every value in the production section and pass
# `pnpm run validate:production-env`.

# --- Required in all environments ---
OPENAI_API_KEY=

# --- Production security contract ---
# Must be `production` on preview/prod deployments.
AINDER_ENV=production
# Comma-separated browser origins allowed to use authenticated agent/MCP routes.
AINDER_ALLOWED_ORIGINS=https://your-web.example.com
# At least 32 random characters. Used to sign server-side session IDs.
AINDER_SESSION_SECRET=
# Bootstrap account for the first production operator/user.
AINDER_BOOTSTRAP_USER_ID=
# scrypt:<saltHex>:<hashHex>. Generate out-of-band; never store raw passwords.
AINDER_BOOTSTRAP_PASSWORD_HASH=
# Durable state/session files or mounted volume paths.
AINDER_DATA_FILE=/data/ainder-state.json
AINDER_SESSION_STORE_FILE=/data/ainder-agent-sessions.json

# --- Production service URLs (no localhost) ---
GGUI_MCP_URL=https://your-ggui-mcp.example.com/mcp
GGUI_AINDER_MCP_URL=https://your-ainder-mcp.example.com/mcp
VITE_AGENT_ENDPOINT_URL=https://your-agent.example.com
SANDBOX_PROXY_PUBLIC_URL=https://your-agent-sandbox.example.com

# --- Provider secrets ---
COCOUN_API_KEY=
TOBL_API_KEY=

# --- Railway deployment ---
RAILWAY_API_TOKEN=

# --- Production security contracts ---
# Comma-separated browser origins allowed to call the agent/MCP surfaces.
# Production values must be HTTPS and must not include localhost.
AINDER_ALLOWED_ORIGINS=

# Required in production for server-side secure cookie sessions.
AINDER_SESSION_SECRET=

# Demo/bootstrap switches. Keep false for preview/production.
AINDER_ALLOW_DEMO_BOOTSTRAP=false
AINDER_ENABLE_ADMIN_DEBUG=false

# --- Wire the AInder MCP into the agent (local dev default shown) ---

# Registers the AInder domain tools alongside ggui_* tools.
GGUI_AINDER_MCP_URL=http://localhost:6782/mcp

# Future real-provider wiring (not required by the current demo implementation)
# COCOUN_API_KEY=
# TOBL_API_KEY=

# --- Optional overrides (defaults shown) ---

# Where the agent's MCP client connects for ggui_* (render) tools.
# GGUI_MCP_URL=http://localhost:6781/mcp
# GGUI_AINDER_MCP_URL=http://localhost:6782/mcp
# GGUI_MCP_BEARER=dev
# OPENAI_MODEL=gpt-5.5
# PORT=6790
# VITE_AGENT_ENDPOINT_URL=http://localhost:6790
