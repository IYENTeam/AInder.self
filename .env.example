# Copy to `.env.local` (git-ignored) for local development.
# Production/preview values must be set explicitly by the deploy platform;
# localhost defaults are local-dev only and are rejected by env validation.

# --- Required for all non-demo agent runs ---

OPENAI_API_KEY=

# Public browser-facing agent URL. Required for production web builds.
# Local dev may omit this and use http://localhost:6790.
VITE_AGENT_ENDPOINT_URL=

# Explicit browser origins allowed to call backend/MCP surfaces in production.
# Example: https://app.example.com,https://agent.example.com
AINDER_ALLOWED_ORIGINS=

# Cookie/session and admin controls. Use long random secrets in production.
AINDER_SESSION_SECRET=
AINDER_ADMIN_TOKEN=

# Bootstrap credentials for the current production auth bridge.
# Replace with real user/session persistence once full auth rollout is complete.
AINDER_BOOTSTRAP_USER=demo
AINDER_BOOTSTRAP_PASSWORD=demo
# Optional pre-hashed override (scrypt:v1:<salt>:<derived>) for production.
AINDER_BOOTSTRAP_PASSWORD_HASH=

# Durable AInder store path for the MCP service. Required in production.
AINDER_STORE_PATH=.data/ainder-store.json

# Optional dedicated session-store file for the agent auth bridge.
AINDER_SESSION_STORE_PATH=.data/ainder-agent-sessions.json

# Set false in production. Local demo mode seeds fixture users/personas.
AINDER_SEED_DEMO=true

# --- MCP / provider wiring ---

# Required in production; local dev defaults are only convenience values.
GGUI_MCP_URL=http://localhost:6781/mcp
GGUI_AINDER_MCP_URL=http://localhost:6782/mcp

# Real provider credentials. Production validation requires these unless the
# corresponding feature is disabled at rollout time.
COCOUN_API_KEY=
TOBL_API_KEY=

# --- Deploy to Railway (`pnpm deploy:railway`) ---

RAILWAY_API_TOKEN=

# --- Optional local overrides ---

# Bearer sent on every ggui MCP request in local dev.
GGUI_MCP_BEARER=dev

# OpenAI model the agent runs on.
OPENAI_MODEL=gpt-5.5

# Agent and MCP service ports.
PORT=6790
SANDBOX_PROXY_PORT=7791
AINDER_RATE_LIMIT=120
AINDER_RATE_WINDOW_MS=60000
AINDER_MAX_BODY_BYTES=1048576
